# Variáveis necessárias para conectar ao Supabase.
# Copie este arquivo para .env e preencha com suas credenciais,
# ou use .streamlit/secrets.toml com o mesmo formato (recomendado para Streamlit).
#
# Onde encontrar:
# - SUPABASE_URL: Painel do projeto Supabase > Settings > API > Project URL
# - SUPABASE_KEY: Painel do projeto Supabase > Settings > API > anon public (ou service_role)

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-ou-service-role
